<Window x:Class="NetworkAnalysisApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:NetworkAnalysisApp"
        xmlns:viewmodels="clr-namespace:NetworkAnalysisApp.ViewModels"
        mc:Ignorable="d"
        Title="Network Analysis App (Simplified Wireshark Clone)" Height="600" Width="900"
        WindowStartupLocation="CenterScreen">
    
    <!-- Set DataContext via XAML or Code-behind, doing it in code-behind for simplicity given startup -->

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="2*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Top Control Bar -->
        <ToolBarTray Grid.Row="0">
            <ToolBar Padding="4" Band="0">
                <TextBlock Text="Interface: " VerticalAlignment="Center" Margin="0,0,5,0"/>
                <ComboBox ItemsSource="{Binding Devices}" 
                          SelectedItem="{Binding SelectedDevice}" 
                          DisplayMemberPath="Description" 
                          Width="250" 
                          Margin="0,0,15,0"
                          IsEnabled="{Binding IsCapturing, Converter={StaticResource InverseBooleanConverter}}"/>

                <TextBlock Text="Src IP: " VerticalAlignment="Center" Margin="0,0,5,0"/>
                <ComboBox Text="{Binding FilterSourceIp, UpdateSourceTrigger=PropertyChanged}" 
                          ItemsSource="{Binding Config.SrcIpHistory}"
                          IsEditable="True"
                          Width="100" 
                          Margin="0,0,10,0"
                          IsEnabled="{Binding IsCapturing, Converter={StaticResource InverseBooleanConverter}}"/>

                <TextBlock Text="Dst IP: " VerticalAlignment="Center" Margin="0,0,5,0"/>
                <ComboBox Text="{Binding FilterDestinationIp, UpdateSourceTrigger=PropertyChanged}" 
                          ItemsSource="{Binding Config.DstIpHistory}"
                          IsEditable="True"
                          Width="100" 
                          Margin="0,0,15,0"
                          IsEnabled="{Binding IsCapturing, Converter={StaticResource InverseBooleanConverter}}"/>
            </ToolBar>
            <ToolBar Padding="4" Band="1">
                <TextBlock Text="Protocols:" VerticalAlignment="Center" Margin="0,0,5,0"/>
                <ComboBox ItemsSource="{Binding Protocols}" Width="150" Margin="0,0,5,0" IsEnabled="{Binding IsCapturing, Converter={StaticResource InverseBooleanConverter}}">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <CheckBox Content="{Binding Name}" IsChecked="{Binding IsSelected}"/>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
                <Button Content="Edit..." Click="EditProtocols_Click" Margin="0,0,15,0" IsEnabled="{Binding IsCapturing, Converter={StaticResource InverseBooleanConverter}}"/>

                <TextBlock Text="Other Filters: " VerticalAlignment="Center" Margin="0,0,5,0"/>
                <ComboBox Text="{Binding FilterExpression, UpdateSourceTrigger=PropertyChanged}" 
                          ItemsSource="{Binding Config.FilterHistory}"
                          IsEditable="True"
                          Width="150" 
                          Margin="0,0,15,0"
                          IsEnabled="{Binding IsCapturing, Converter={StaticResource InverseBooleanConverter}}"
                          ToolTip="Additional BPF (e.g. port 80)"/>

                <TextBlock Text="Search Payload: " VerticalAlignment="Center" Margin="0,0,5,0" Foreground="DarkBlue" FontWeight="SemiBold"/>
                <ComboBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged, Delay=250}" 
                          ItemsSource="{Binding Config.SearchHistory}"
                          IsEditable="True"
                          Width="150" 
                          Margin="0,0,15,0"
                          ToolTip="Filter live packets by ASCII Payload contents"/>

                <Button Command="{Binding OpenFileCommand}" Margin="0,0,5,0" Padding="10,2" ToolTip="Open PCAP File">📂 Open</Button>
                <Button Command="{Binding SaveFileCommand}" Margin="0,0,5,0" Padding="10,2" ToolTip="Save to PCAP" IsEnabled="{Binding IsCapturing, Converter={StaticResource InverseBooleanConverter}}">💾 Save</Button>
                <Button Click="Dashboard_Click" Margin="0,0,15,0" Padding="10,2" ToolTip="View Traffic Statistics">📊 Dashboard</Button>
                <Button Command="{Binding LaunchBrowserCommand}" Margin="0,0,15,0" Padding="10,2" ToolTip="Launch Browser with SSLKEYLOGFILE enabled" Foreground="DarkRed">🌐 SSL Browser Launch</Button>

                <Button Command="{Binding StartCaptureCommand}" Margin="0,0,5,0" Padding="10,2">▶ Start</Button>
                <Button Command="{Binding StopCaptureCommand}" Margin="0,0,15,0" Padding="10,2">⏹ Stop</Button>
                <ToggleButton x:Name="AutoScrollToggle" Margin="0,0,15,0" Padding="10,2" ToolTip="Automatically scroll to latest packet" IsChecked="True">📜 Auto-Scroll</ToggleButton>
                <Button Command="{Binding ClearPacketsCommand}" Padding="10,2" Margin="0,0,15,0">🗑 Clear</Button>
                <Button Click="Help_Click" Padding="10,2" ToolTip="View Application Manual" Foreground="DarkSlateBlue">❔ Help</Button>
            </ToolBar>
        </ToolBarTray>

        <!-- Packet List -->
        <DataGrid x:Name="PacketDataGrid"
                  Grid.Row="1" 
                  ItemsSource="{Binding PacketsView}" 
                  SelectedItem="{Binding SelectedPacket, Mode=TwoWay}"
                  AutoGenerateColumns="False" 
                  CanUserAddRows="False"
                  IsReadOnly="True"
                  CanUserSortColumns="False"
                  SelectionMode="Single"
                  GridLinesVisibility="All"
                  AlternatingRowBackground="#FFF0F0F0">
            <DataGrid.RowStyle>
                <Style TargetType="DataGridRow">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsHighlighted}" Value="True">
                            <Setter Property="Background" Value="LightYellow" />
                            <Setter Property="FontWeight" Value="SemiBold" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </DataGrid.RowStyle>
            <DataGrid.Columns>
                <DataGridTextColumn Header="No." Binding="{Binding Number}" Width="50" />
                <DataGridTextColumn Header="Time" Binding="{Binding Time, StringFormat={}{0:HH:mm:ss.fff}}" Width="120" />
                <DataGridTextColumn Header="Source" Binding="{Binding ResolvedSourceIp}" Width="150">
                    <DataGridTextColumn.CellStyle>
                        <Style TargetType="DataGridCell">
                            <Setter Property="ToolTip" Value="{Binding SourceIp}" />
                        </Style>
                    </DataGridTextColumn.CellStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Header="Destination" Binding="{Binding ResolvedDestinationIp}" Width="150">
                    <DataGridTextColumn.CellStyle>
                        <Style TargetType="DataGridCell">
                            <Setter Property="ToolTip" Value="{Binding DestinationIp}" />
                        </Style>
                    </DataGridTextColumn.CellStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Header="Protocol" Binding="{Binding Protocol}" Width="80" />
                <DataGridTextColumn Header="Length" Binding="{Binding Length}" Width="80" />
                <DataGridTextColumn Header="Info" Binding="{Binding Info}" Width="*" />
            </DataGrid.Columns>
        </DataGrid>

        <GridSplitter Grid.Row="2" Height="5" HorizontalAlignment="Stretch" Background="LightGray"/>

        <!-- Packet Inspector -->
        <GroupBox Grid.Row="3" Header="Packet Inspector" Margin="5">
            <Grid Margin="5">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="5"/>
                    <ColumnDefinition Width="3*"/>
                    <ColumnDefinition Width="5"/>
                    <ColumnDefinition Width="2*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="Select a packet to view details." 
                           Grid.Column="0" Grid.ColumnSpan="5"
                           Visibility="{Binding SelectedPacket, Converter={StaticResource NullToVisibilityConverter}, ConverterParameter=Inverse}"/>
                
                <Grid Grid.Column="0" Visibility="{Binding SelectedPacket, Converter={StaticResource NullToVisibilityConverter}}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Number: " FontWeight="Bold" Margin="0,2,5,2"/>
                    <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding SelectedPacket.Number}" Margin="0,2,0,2"/>

                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Time: " FontWeight="Bold" Margin="0,2,5,2"/>
                    <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding SelectedPacket.Time, StringFormat={}{0:yyyy-MM-dd HH:mm:ss.fff}}" Margin="0,2,0,2"/>

                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Source: " FontWeight="Bold" Margin="0,2,5,2"/>
                    <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding SelectedPacket.SourceIp}" Margin="0,2,0,2"/>

                    <TextBlock Grid.Row="3" Grid.Column="0" Text="Destination: " FontWeight="Bold" Margin="0,2,5,2"/>
                    <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding SelectedPacket.DestinationIp}" Margin="0,2,0,2"/>

                    <TextBlock Grid.Row="4" Grid.Column="0" Text="Protocol Info: " FontWeight="Bold" Margin="0,2,5,2"/>
                    <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding SelectedPacket.Info}" Margin="0,2,0,2" TextWrapping="Wrap"/>
                </Grid>

                <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch" Background="LightGray"/>
                
                <!-- Hex Dump and ASCII Text Tabs -->
                <TabControl Grid.Column="2" Grid.ColumnSpan="3" Visibility="{Binding SelectedPacket, Converter={StaticResource NullToVisibilityConverter}}">
                    <TabItem Header="Hex View">
                        <TextBox Text="{Binding SelectedPacketHex, Mode=OneWay}" 
                                 FontFamily="Consolas" 
                                 TextWrapping="Wrap" 
                                 AcceptsReturn="True" 
                                 IsReadOnly="True" 
                                 BorderBrush="{DynamicResource ControlBorderBrush}"
                                 Background="{DynamicResource ControlBackgroundBrush}"
                                 Foreground="{DynamicResource ForegroundBrush}"/>
                    </TabItem>
                    
                    <TabItem Header="Hex View (Decrypted)">
                        <TextBox Text="{Binding SelectedPacket.DecryptedHex, Mode=OneWay}" 
                                 FontFamily="Consolas" 
                                 TextWrapping="Wrap" 
                                 AcceptsReturn="True" 
                                 IsReadOnly="True" 
                                 BorderBrush="{DynamicResource ControlBorderBrush}"
                                 Background="{DynamicResource ControlBackgroundBrush}"
                                 Foreground="{DynamicResource ForegroundBrush}"/>
                    </TabItem>

                    <!-- Text View Tab -->
                    <TabItem Header="Text View">
                        <TextBox Text="{Binding SelectedPacketText, Mode=OneWay}" 
                                 FontFamily="Consolas" 
                                 TextWrapping="Wrap" 
                                 AcceptsReturn="True" 
                                 IsReadOnly="True" 
                                 BorderBrush="{DynamicResource ControlBorderBrush}"
                                 Background="{DynamicResource ControlBackgroundBrush}"
                                 Foreground="{DynamicResource ForegroundBrush}"/>
                    </TabItem>
                    
                    <TabItem Header="Text View (Decrypted)">
                        <TextBox Text="{Binding SelectedPacket.DecryptedText, Mode=OneWay}" 
                                 FontFamily="Consolas" 
                                 TextWrapping="Wrap" 
                                 AcceptsReturn="True" 
                                 IsReadOnly="True" 
                                 BorderBrush="{DynamicResource ControlBorderBrush}"
                                 Background="{DynamicResource ControlBackgroundBrush}"
                                 Foreground="{DynamicResource ForegroundBrush}"/>
                    </TabItem>
                </TabControl>
            </Grid>
        </GroupBox>

        <!-- Status Bar -->
        <StatusBar Grid.Row="4">
            <StatusBarItem>
                <TextBlock>
                    <Run Text="Total Packets Captured: "/>
                    <Run Text="{Binding TotalPacketsCaptured}"/>
                </TextBlock>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>
